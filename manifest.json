{
  "name": "System Monitor",
  "version": "1.0.2",
  "entry": "index.js",
  "description": "Real-time system monitoring widget — CPU, memory, battery, disk, and network stats",
  "author": "MyWallpapers",
  "homepage": "https://github.com/MyWallpapers/mywallpaper-addon-system-monitor",
  "license": "MIT",
  "repository": "https://github.com/MyWallpapers/mywallpaper-addon-system-monitor",
  "categories": [
    "utilities",
    "system"
  ],
  "permissions": {
    "system": true
  },
  "settings": {
    "displaySection": {
      "type": "section",
      "content": {
        "label": "Display Options"
      }
    },
    "showCPU": {
      "type": "boolean",
      "content": {
        "label": "Show CPU",
        "default": true
      }
    },
    "showMemory": {
      "type": "boolean",
      "content": {
        "label": "Show Memory",
        "default": true
      }
    },
    "showBattery": {
      "type": "boolean",
      "content": {
        "label": "Show Battery",
        "default": true
      }
    },
    "showDisk": {
      "type": "boolean",
      "content": {
        "label": "Show Disk",
        "default": false
      }
    },
    "showNetwork": {
      "type": "boolean",
      "content": {
        "label": "Show Network",
        "default": false
      }
    },
    "refreshInterval": {
      "type": "select",
      "content": {
        "label": "Refresh Rate",
        "options": [
          {
            "label": "3 seconds",
            "value": "3s"
          },
          {
            "label": "5 seconds",
            "value": "5s"
          },
          {
            "label": "10 seconds",
            "value": "10s"
          }
        ],
        "default": "3s"
      }
    },
    "themeSection": {
      "type": "section",
      "content": {
        "label": "Theme"
      }
    },
    "backgroundColor": {
      "type": "color",
      "content": {
        "label": "Background",
        "default": "#1a1a2e"
      }
    },
    "textColor": {
      "type": "color",
      "content": {
        "label": "Text Color",
        "default": "#00ff88"
      }
    },
    "accentColor": {
      "type": "color",
      "content": {
        "label": "Accent Color",
        "default": "#00ccff"
      }
    },
    "transparency": {
      "type": "range",
      "content": {
        "label": "Transparency",
        "min": 0,
        "max": 1,
        "step": 0.1,
        "default": 0.85
      }
    }
  },
  "defaultLayout": {
    "xPercent": 2,
    "yPercent": 2,
    "widthPercent": 20,
    "heightPercent": 35,
    "rotation": 0
  },
  "ui": {
    "pointerEvents": "none"
  }
}
